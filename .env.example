# Copy this file to ".env" and paste your sponsor keys.
# The app runs fine with these blank — it falls back to built-in warm content.
# It "lights up" with live AI + citations the moment you add keys.

# ── Nebius Token Factory (writes the warm daily briefing) ──────────────────────
# Get credits: https://dev.nebius.com//builders  +  promo TOKENFACTORY-100-DXL
# Key from: https://tokenfactory.nebius.com  → profile → API keys
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1
NEBIUS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# ── Tavily (citation-backed evidence for the "why" cards) ──────────────────────
# Docs: https://docs.tavily.com  → dashboard → API key
TAVILY_API_KEY=

# ── InsForge (real journal persistence) ────────────────────────────────────────
# Your project's REST base URL + key. Blank = in-memory fallback (offline-safe).
INSFORGE_API_URL=
INSFORGE_API_KEY=
INSFORGE_TABLE=journal_entries

PORT=8787
